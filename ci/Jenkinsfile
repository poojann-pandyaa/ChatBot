pipeline {
    agent any
    
    triggers {
        pollSCM('* * * * *')
    }
    
    tools {
        nodejs 'node20'
    }
    
    environment {
        DOCKER_REGISTRY = 'poojannpandyaa'
        IMAGE_TAG = 'latest'
        PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
    }
    
    stages {
        stage('Git Checkout') {
            steps {
                // Checkout current repo
                checkout scm
            }
        }
        
        stage('Unit Testing') {
            steps {
                sh '''
                python3 -m venv venv
                . venv/bin/activate
                pip install --upgrade pip
                pip install requests sentence-transformers elasticsearch qdrant-client || true
                '''
                sh 'mvn test -Dnet.bytebuddy.experimental=true'
            }
        }
        
        stage('Trivy Filesystem Scan') {
            steps {
                sh "trivy fs services/ > trivy-fs-report.json || true"
            }
        }
        
        stage('Build Container Images') {
            parallel {
                stage('Build RAG Engine') {
                    steps {
                        sh "docker build -t ${DOCKER_REGISTRY}/rag-engine:${IMAGE_TAG} services/rag-engine/"
                    }
                }
                stage('Build App Gateway') {
                    steps {
                        sh "docker build -t ${DOCKER_REGISTRY}/app-gateway:${IMAGE_TAG} services/app-gateway/"
                    }
                }
                stage('Build Frontend Chatbot UI') {
                    steps {
                        sh "docker build -t ${DOCKER_REGISTRY}/frontend:${IMAGE_TAG} services/frontend/"
                    }
                }
            }
        }
        
        stage('Trivy Container Scan') {
            parallel {
                stage('Scan RAG Engine') {
                    steps {
                        sh "trivy image --severity HIGH,CRITICAL ${DOCKER_REGISTRY}/rag-engine:${IMAGE_TAG} > trivy-rag-report.json || true"
                    }
                }
                stage('Scan App Gateway') {
                    steps {
                        sh "trivy image --severity HIGH,CRITICAL ${DOCKER_REGISTRY}/app-gateway:${IMAGE_TAG} > trivy-gateway-report.json || true"
                    }
                }
                stage('Scan Frontend') {
                    steps {
                        sh "trivy image --severity HIGH,CRITICAL ${DOCKER_REGISTRY}/frontend:${IMAGE_TAG} > trivy-frontend-report.json || true"
                    }
                }
            }
        }
        
        stage('Push to Registry') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                        sh "docker login -u ${DOCKER_USER} -p ${DOCKER_PASS}"
                        sh "docker push ${DOCKER_REGISTRY}/rag-engine:${IMAGE_TAG}"
                        sh "docker push ${DOCKER_REGISTRY}/app-gateway:${IMAGE_TAG}"
                        sh "docker push ${DOCKER_REGISTRY}/frontend:${IMAGE_TAG}"
                    }
                }
            }
        }
        
        stage('Orchestrate Deploy via Ansible') {
            steps {
                sh """
                ansible-playbook -i ansible/inventory.ini ansible/playbooks/deploy.yml \
                    -e docker_registry=${env.DOCKER_REGISTRY} \
                    -e image_tag=${env.IMAGE_TAG} \
                    -e ansible_python_interpreter=${WORKSPACE}/venv/bin/python
                """
            }
        }
        
        stage('Database Seeding') {
            steps {
                sh '''
                # Start port-forwarding in background
                kubectl port-forward svc/qdrant 6333:6333 -n llmops-platform &
                QDRANT_PID=$!
                kubectl port-forward svc/elasticsearch 9200:9200 -n llmops-platform &
                ES_PID=$!
                kubectl port-forward svc/ml-service 8000:8000 -n llmops-platform &
                ML_PID=$!
                
                # Wait for port-forwarding to establish
                sleep 5
                
                # Run ingestion script
                . venv/bin/activate
                python3 training/ingestion/run_ingestion.py --limit 1000
                
                # Kill port-forwarding processes
                kill $QDRANT_PID $ES_PID $ML_PID || true
                '''
            }
        }
        
        stage('Sanity Verification') {
            steps {
                sh '''
                # Start port-forwarding for app-gateway
                kubectl port-forward svc/app-gateway 8089:8080 -n llmops-platform &
                GW_PID=$!
                
                # Wait for port-forwarding to establish
                sleep 5
                
                # Send a curl request and verify output
                RESPONSE=$(curl -s -X POST http://localhost:8089/api/chat \
                  -H "Content-Type: application/json" \
                  -d '{"prompt": "How do I reverse a list in Python?", "conversation_id": "sanity-check", "debug": true, "stream": false}')
                  
                echo "Sanity Check Response: $RESPONSE"
                
                # Verify Prometheus metrics endpoint
                METRICS_RESPONSE=$(curl -s http://localhost:8089/metrics)
                echo "Metrics Response: $METRICS_RESPONSE"
                
                # Kill port-forwarding
                kill $GW_PID || true
                
                # Verify response contains expected fields
                if echo "$RESPONSE" | grep -q '"answer"'; then
                  echo "Sanity Check Passed!"
                else
                  echo "Sanity Check Failed!"
                  exit 1
                fi
                
                # Verify metrics contains gateway requests metric
                if echo "$METRICS_RESPONSE" | grep -q "gateway_requests_total"; then
                  echo "Prometheus Metrics Check Passed!"
                else
                  echo "Prometheus Metrics Check Failed!"
                  exit 1
                fi
                '''
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
    }
}
