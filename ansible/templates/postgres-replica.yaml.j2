apiVersion: apps/v1
kind: Deployment
metadata:
  name: postgres-replica
  namespace: {{ k8s_namespace }}
  labels:
    app: postgres-replica
spec:
  replicas: 1
  selector:
    matchLabels:
      app: postgres-replica
  template:
    metadata:
      labels:
        app: postgres-replica
    spec:
      containers:
      - name: postgres-replica
        image: bitnami/postgresql:15
        imagePullPolicy: IfNotPresent
        env:
        - name: POSTGRESQL_REPLICATION_MODE
          value: "slave"
        - name: POSTGRESQL_MASTER_HOST
          value: "postgres"
        - name: POSTGRESQL_MASTER_PORT_NUMBER
          value: "5432"
        - name: POSTGRESQL_REPLICATION_USER
          value: "replicator"
        - name: POSTGRESQL_REPLICATION_PASSWORD
          value: "ReplicatorPassword123"
        - name: POSTGRESQL_PASSWORD
          valueFrom:
            secretKeyRef:
              name: llmops-secrets
              key: postgres-password
        ports:
        - containerPort: 5432
          name: postgres
        resources:
          requests:
            memory: "128Mi"
            cpu: "100m"
          limits:
            memory: "512Mi"
            cpu: "500m"
        readinessProbe:
          tcpSocket:
            port: 5432
          initialDelaySeconds: 5
          periodSeconds: 5
        livenessProbe:
          tcpSocket:
            port: 5432
          initialDelaySeconds: 10
          periodSeconds: 10
---
apiVersion: v1
kind: Service
metadata:
  name: postgres-replica
  namespace: {{ k8s_namespace }}
  labels:
    app: postgres-replica
spec:
  type: ClusterIP
  ports:
  - port: 5432
    targetPort: 5432
    name: postgres
  selector:
    app: postgres-replica
