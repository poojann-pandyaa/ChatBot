apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: redpanda
  namespace: {{ k8s_namespace }}
  labels:
    app: redpanda
spec:
  serviceName: redpanda
  replicas: 1
  selector:
    matchLabels:
      app: redpanda
  template:
    metadata:
      labels:
        app: redpanda
    spec:
      containers:
      - name: redpanda
        image: redpandadata/redpanda:v23.3.8
        imagePullPolicy: IfNotPresent
        command:
        - redpanda
        - start
        - --smp
        - "1"
        - --overprovisioned
        - --node-id
        - "0"
        - --kafka-addr
        - PLAINTEXT://0.0.0.0:29092,OUTSIDE://0.0.0.0:9092
        - --advertise-kafka-addr
        - PLAINTEXT://redpanda:29092,OUTSIDE://localhost:9092
        ports:
        - containerPort: 29092
          name: internal
        - containerPort: 9092
          name: external
        resources:
          requests:
            memory: "512Mi"
            cpu: "250m"
          limits:
            memory: "1Gi"
            cpu: "1000m"
        readinessProbe:
          exec:
            command:
            - rpk
            - cluster
            - health
          initialDelaySeconds: 15
          periodSeconds: 10
        livenessProbe:
          exec:
            command:
            - rpk
            - cluster
            - health
          initialDelaySeconds: 20
          periodSeconds: 15
---
apiVersion: v1
kind: Service
metadata:
  name: redpanda
  namespace: {{ k8s_namespace }}
  labels:
    app: redpanda
spec:
  clusterIP: None
  ports:
  - port: 29092
    targetPort: 29092
    name: internal
  - port: 9092
    targetPort: 9092
    name: external
  selector:
    app: redpanda
