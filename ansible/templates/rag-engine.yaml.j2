apiVersion: apps/v1
kind: Deployment
metadata:
  name: rag-engine
  namespace: {{ k8s_namespace }}
  labels:
    app: rag-engine
spec:
  replicas: 1
  selector:
    matchLabels:
      app: rag-engine
  template:
    metadata:
      labels:
        app: rag-engine
    spec:
      containers:
      - name: rag-engine
        image: {{ docker_registry }}/rag-engine:{{ image_tag }}
        imagePullPolicy: Always
        env:
        - name: ML_SERVICE_URL
          value: "http://ml-service:8000"
        - name: REDIS_HOST
          value: "redis"
        - name: REDIS_PORT
          value: "6379"
        - name: REDIS_PASSWORD
          value: "{{ redis_password }}"
        - name: QDRANT_URL
          value: "http://qdrant:6333"
        - name: ELASTICSEARCH_URL
          value: "http://elasticsearch:9200"
        - name: OLLAMA_URL
          value: "http://ollama:11434"
        - name: OLLAMA_MODEL
          value: "{{ ollama_model }}"
        - name: VAULT_ENABLED
          value: "true"
        - name: VAULT_ADDR
          value: "http://vault:8200"
        - name: VAULT_TOKEN
          value: "{{ vault_root_token }}"
        - name: VAULT_SECRET_PATH
          value: "{{ vault_secret_path }}"
        - name: HF_HUB_OFFLINE
          value: "1"
        - name: HF_DATASETS_OFFLINE
          value: "1"
        - name: TRANSFORMERS_OFFLINE
          value: "1"
        - name: OMP_NUM_THREADS
          value: "1"
        - name: MKL_NUM_THREADS
          value: "1"
        ports:
        - containerPort: 8000
          name: http
        resources:
          requests:
            memory: "768Mi"
            cpu: "200m"
          limits:
            memory: "6Gi"
            cpu: "2000m"
        startupProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 10
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 30
        readinessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 10
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 6
        livenessProbe:
          httpGet:
            path: /health
            port: 8000
          initialDelaySeconds: 15
          periodSeconds: 15
          timeoutSeconds: 5
          failureThreshold: 6
---
apiVersion: v1
kind: Service
metadata:
  name: rag-engine
  namespace: {{ k8s_namespace }}
  labels:
    app: rag-engine
spec:
  type: ClusterIP
  ports:
  - port: 8000
    targetPort: 8000
    name: http
  selector:
    app: rag-engine
